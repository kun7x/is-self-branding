{
    "colors": {
        "background": "#F7F6F3",
        "backgroundCard": "#FFFFFF",
        "accent": "#0E6FFF",
        "accentHover": "#0B5CD5",
        "text": "#222222",
        "textSecondary": "#666666",
        "textMuted": "#999999",
        "border": "#E5E3DF",
        "borderLight": "#EEECE8"
    },
    "typography": {
        "fontFamily": "'Inter', system-ui, -apple-system, sans-serif",
        "scale": {
            "h1": {
                "size": "2.5rem",
                "weight": 300,
                "lineHeight": 1.2
            },
            "h2": {
                "size": "1.75rem",
                "weight": 300,
                "lineHeight": 1.3
            },
            "h3": {
                "size": "1.25rem",
                "weight": 500,
                "lineHeight": 1.4
            },
            "body": {
                "size": "1rem",
                "weight": 400,
                "lineHeight": 1.7
            },
            "small": {
                "size": "0.875rem",
                "weight": 400,
                "lineHeight": 1.5
            },
            "caption": {
                "size": "0.75rem",
                "weight": 500,
                "lineHeight": 1.4
            }
        }
    },
    "spacing": {
        "xs": "0.25rem",
        "sm": "0.5rem",
        "md": "1rem",
        "lg": "1.5rem",
        "xl": "2rem",
        "2xl": "3rem",
        "3xl": "4rem",
        "section": "5rem",
        "sectionMobile": "3rem"
    },
    "radii": {
        "sm": "6px",
        "md": "10px",
        "lg": "16px",
        "full": "9999px"
    },
    "shadows": {
        "card": "0 1px 3px rgba(0,0,0,0.04), 0 1px 2px rgba(0,0,0,0.06)",
        "cardHover": "0 10px 30px rgba(0,0,0,0.08)",
        "nav": "0 1px 0 rgba(0,0,0,0.04)"
    },
    "transitions": {
        "fast": "150ms cubic-bezier(0.22, 1, 0.36, 1)",
        "normal": "250ms cubic-bezier(0.22, 1, 0.36, 1)",
        "slow": "350ms cubic-bezier(0.22, 1, 0.36, 1)"
    }
}